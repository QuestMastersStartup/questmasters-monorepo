# ═══════════════════════════════════════════════════════════════════════════════
# QuestMasters — Variables de entorno unificadas
# ═══════════════════════════════════════════════════════════════════════════════
# Copia este archivo a .env y rellena los valores reales:
#   cp .env.example .env
#
# Este archivo es leído por todos los apps del monorepo.
# .env está en .gitignore — nunca se commitea.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend (Cloudflare Workers) ─────────────────────────────────────────────
JWT_SECRET=local-dev-secret-do-not-use-in-production

# ── DM Model endpoints ──────────────────────────────────────────────────────
# URL del servidor del modelo (Colab ngrok o RunPod)
DM_MODEL_ENDPOINT_MAS=http://localhost:9999/placeholder
DM_MODEL_ENDPOINT_MONOLITHIC=http://localhost:9999/placeholder

# ── RunPod Serverless (opcional, solo si DM_USE_RUNPOD=true) ─────────────────
DM_USE_RUNPOD=false
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://127.0.0.1:3000

# ── DM Orchestrator (Colab) ──────────────────────────────────────────────────
# Estos van en los Secretos de Colab (panel de llave), no aquí.
# Se listan como referencia:
# HF_TOKEN=hf_xxx
# NGROK_TOKEN=xxx
