---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/landing/Navigation.astro";
import HeroSection from "../components/landing/HeroSection.astro";
import ProblemSolutionSection from "../components/landing/ProblemSolutionSection.astro";
import VisionSection from "../components/landing/VisionSection.astro";
import FeaturesSection from "../components/landing/FeaturesSection.astro";
import DemoSection from "../components/landing/DemoSection.astro";
import TestimonialsSection from "../components/landing/TestimonialsSection.astro";
import PricingSection from "../components/landing/PricingSection.astro";
import FAQSection from "../components/landing/FAQSection.astro";
import CTASection from "../components/landing/CTASection.astro";
import Footer from "../components/landing/Footer.astro";
---

<Layout>
  <div class="min-h-screen relative">
    <div class="golden-rain"></div>
    <Navigation />
    <HeroSection />
    <ProblemSolutionSection />
    <VisionSection />
    <FeaturesSection />
    <DemoSection />
    <TestimonialsSection />
    <PricingSection />
    <FAQSection />
    <CTASection />
    <Footer />
  </div>
</Layout>
