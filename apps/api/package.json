{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "description": "QuestMasters API - Bun + Elysia",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --sourcemap && bun -e \"import { cpSync } from 'node:fs'; cpSync('src/rules-engine/infrastructure/seeding/data', './dist/data', { recursive: true })\"",
    "start": "bun run src/index.ts",
    "start:prod": "bun run dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migration:generate": "bun x typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:create": "bun x typeorm-ts-node-commonjs migration:create",
    "migration:run": "bun x typeorm-ts-node-commonjs migration:run -d src/data-source.ts",
    "migration:revert": "bun x typeorm-ts-node-commonjs migration:revert -d src/data-source.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2",
    "@elysiajs/swagger": "^1.3.1",
    "@questmasters/dnd-rules": "workspace:^",
    "@supabase/supabase-js": "^2.93.2",
    "elysia": "^1.2",
    "elysia-rate-limit": "^4.5.0",
    "pg": "^8.17.2",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  }
}
