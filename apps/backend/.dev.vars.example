# Copia este archivo a .dev.vars y rellena los valores reales.
# .dev.vars es ignorado por git (ver .gitignore).
#
# ── Setup inicial (una sola vez tras clonar) ─────────────────────────────────
#
#   1. cp apps/backend/.dev.vars.example apps/backend/.dev.vars
#   2. Aplica las migraciones D1 locales:
#        cd apps/backend
#        bunx wrangler d1 migrations apply questmasters --local --env preview
#   3. bun install && bun run dev
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=local-dev-secret-do-not-use-in-production

# ─── DM Model endpoints ──────────────────────────────────────────────────────
# Para modo local con Gemma 4 E4B, apuntar al local_server.py:
#   DM_MODEL_ENDPOINT_MAS=http://localhost:8000
#   DM_MODEL_ENDPOINT_MONOLITHIC=http://localhost:8000
DM_MODEL_ENDPOINT_MAS=http://localhost:9999/placeholder
DM_MODEL_ENDPOINT_MONOLITHIC=http://localhost:9999/placeholder

# ─── RunPod Serverless ───────────────────────────────────────────────────────
DM_USE_RUNPOD=false
RUNPOD_ENDPOINT_ID=
RUNPOD_API_KEY=
