{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "description": "QuestMasters API - Bun + Elysia",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "wrangler dev --env preview --port 3000",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --sourcemap && bun -e \"import { cpSync } from 'node:fs'; cpSync('src/content/infrastructure/seeding/data', './dist/data', { recursive: true })\"",
    "start": "bun run src/index.ts",
    "start:prod": "bun run dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "migration:generate": "bun x typeorm-ts-node-commonjs migration:generate -d src/data-source.ts",
    "migration:create": "bun x typeorm-ts-node-commonjs migration:create",
    "migration:run": "bun --env-file=.env scripts/migration-run.ts",
    "migration:revert": "bun --env-file=.env scripts/migration-revert.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@questmasters/dnd-rules": "workspace:^",
    "@supabase/supabase-js": "^2.93.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@types/bun": "latest",
    "drizzle-kit": "0.28.0",
    "esbuild": "0.27.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.100.0"
  }
}
